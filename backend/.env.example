# =============================================================================
# SUPABASE CONFIGURATION (Required for Video Generation)
# =============================================================================
# Your Supabase project URL (from Supabase dashboard -> Settings -> API)
SUPABASE_URL=https://your-project.supabase.co

# Supabase anon key (public key) - from Settings -> API
SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key (private key) - from Settings -> API
# WARNING: This key has full admin access to your Supabase project
# Get it from: Supabase Dashboard -> Settings -> API -> service_role secret
SUPABASE_SERVICE_KEY=your-service-role-key-here

# =============================================================================
# EXISTING KEYS (From your current configuration)
# =============================================================================
FRONTEND_URL=http://localhost:5173

# Google OAuth (for YouTube channel access)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI_CHANNELS=http://localhost:8000/api/channels/oauth/callback
GOOGLE_REDIRECT_URI_DRIVE=http://localhost:8000/api/drive/oauth/callback


# =============================================================================
# YOUTUBE & AI API KEYS
# =============================================================================
# YouTube Data API Key (from Google Cloud Console)
YOUTUBE_API_KEY=your-youtube-api-key

# Gemini API Settings (used for topic suggestion + topic validation ONLY — lightweight tasks)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash-lite

# Story generation model — uses Vertex AI (same service account as Veo, no separate key)
STORY_MODEL=gemini-2.5-pro


# =============================================================================
# VERTEX AI VIDEO GENERATION (Google Cloud Console credits)
# =============================================================================
# Service account JSON file — place in backend/ folder, put filename here only
GOOGLE_APPLICATION_CREDENTIALS=your-service-account-key.json
# Your Google Cloud project ID
VERTEX_AI_PROJECT_ID=your-gcp-project-id
# Vertex AI region (Veo is available in us-central1)
VERTEX_AI_LOCATION=us-central1
# Veo model: veo-3.1-lite-generate-001 (testing) | veo-3.1-generate-preview (production)
VEO_MODEL=veo-3.1-lite-generate-001


# =============================================================================
# VIDEO GENERATION (Veo 3.1 + Cloudflare R2)
# =============================================================================
# Veo 3.1 uses GEMINI_API_KEY above (no extra key needed).
# Model is hardcoded to veo-3.1-generate-preview, resolution locked to 720p.

# Cloudflare Workers & R2 (for video storage)
# Get these from your Cloudflare dashboard
WORKER_URL=https://your-worker.workers.dev
R2_UPLOAD_API_KEY=your-r2-upload-key
R2_FINAL_PUBLIC_URL=https://pub-your-final-video-url.r2.dev
R2_TRASH_PUBLIC_URL=https://pub-your-trash-video-url.r2.dev

# R2 Direct Access (Optional)
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key


# =============================================================================
# TOPIC SUGGESTION SETTINGS (Optional — defaults are sensible)
# =============================================================================
TOPIC_SUGGESTION_MIN_ENGAGEMENT=0.01   # min (likes+comments)/views engagement ratio filter
TOPIC_SUGGESTION_TOP_N=5               # number of topic suggestions to return
TOPIC_SUGGESTION_TIMEOUT=60            # LLM request timeout in seconds
TOPIC_SUGGESTION_CACHE_TTL=1800        # Redis cache TTL in seconds (30 min)


# =============================================================================
# REDIS CACHE (Optional)
# =============================================================================
REDIS_ENABLED=true
REDIS_HOST=redis-host
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_DB=0
REDIS_TTL_SECONDS=3600
REDIS_SSL=false
