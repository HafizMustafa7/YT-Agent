# Copy to frontend/.env and fill values (Vite only exposes VITE_* to the browser)
VITE_API_URL=http://localhost:8000
VITE_SUPABASE_URL=https://your-project.supabase.co
# Dashboard → Settings → API → anon public key (role must be "anon", not service_role)
VITE_SUPABASE_ANON_KEY=your-supabase-anon-public-key

# Optional — Paddle checkout (sandbox defaults in code if unset)
# VITE_PADDLE_ENVIRONMENT=sandbox
# VITE_PADDLE_CLIENT_TOKEN=your-paddle-client-token
